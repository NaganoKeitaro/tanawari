        HOME["HOME<br/>HomePage"]
        DASH["Dashboard<br/>Dashboard"]
        ANALYTICS["Analytics<br/>Analytics"]
    end

    subgraph SG2["Master Management"]
        PROD["Product Master<br/>ProductMaster"]
        HIER["Hierarchy Master<br/>ProductHierarchyMaster"]
        FIX["Fixture Master<br/>FixtureMaster"]
        STORE["Store Master<br/>StoreMaster"]
        SFIX["Store Fixture<br/>StoreFixtureMaster"]
    end

    subgraph SG3["Planogram Management"]
        BLOCK["Shelf Block<br/>ShelfBlockEditor"]
        STD["Standard Planogram<br/>StandardPlanogramEditor"]
