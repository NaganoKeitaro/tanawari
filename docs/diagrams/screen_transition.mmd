    subgraph SG4["Reports and Others"]
        INST["Instruction Sheet<br/>InstructionSheet"]
        DEL["Bulk Delete<br/>BulkDelete"]
    end

    HOME --> DASH
    HOME --> ANALYTICS
    HOME --> PROD
    HOME --> STORE
    HOME --> FIX
    HOME --> SFIX
    HOME --> HIER
    HOME --> BLOCK
    HOME --> STD
    HOME --> BATCH
    HOME --> INST
    HOME --> DEL

    PROD -.->|Product Data| BLOCK
    FIX -.->|Fixture Data| SFIX
    SFIX -.->|Fixture Layout| STD
    BLOCK -.->|Block Placement| STD
    STD -.->|Standard Planogram| BATCH
    BATCH -->|Store Selection| SPED
    SPED -.->|Planogram Data| INST
    ANALYTICS -.->|Analysis| STD

    classDef dashboard fill:#e0f2fe,stroke:#0284c7
    classDef master fill:#fef3c7,stroke:#d97706
    classDef planogram fill:#dcfce7,stroke:#16a34a
    classDef report fill:#f3e8ff,stroke:#9333ea

    class HOME,DASH,ANALYTICS dashboard
    class PROD,HIER,FIX,STORE,SFIX master
    class BLOCK,STD,BATCH,SPED planogram
    class INST,DEL report
